# Nerdometer — environment variables
# Copy this file to .env.local for local development.
# In production: set these in your Vercel project dashboard under Settings → Environment Variables.

# Per-show nonce — generates the secret URL for live audience leaderboard access.
# Change this before every show. Never reuse a previous show's nonce.
# Generate one with: openssl rand -hex 3
# Then your live audience QR code URL is: https://your-site.com/?n=<value>
VITE_SHOW_NONCE=your_nonce_here
