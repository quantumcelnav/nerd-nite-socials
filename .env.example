# Nerdometer — environment variables
# Copy this file to .env.local for local dev.
# In production: set all of these in Vercel → Settings → Environment Variables.

# Supabase — create a free project at supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Per-show nonce — secret code for live audience leaderboard access.
# Generate: openssl rand -hex 3
# QR code URL: https://your-site.com/?n=<value>
# Update in Vercel before each show — old nonce dies automatically.
VITE_SHOW_NONCE=your_nonce_here
