# Nerdometer — environment variables
# Copy this file to .env.local for local dev.
# In production: set these in Vercel → Settings → Environment Variables.

# Supabase — create a free project at supabase.com
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Show nonce lives in edition.json — no env var needed.
# Update edition.json before each show and push to main.

# Admin panel token — keep this private. Set in Vercel + locally.
# Access the panel at: /?admin=<your-token>
# Generate with: openssl rand -hex 8
VITE_ADMIN_TOKEN=your-token-here
